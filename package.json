{
  "name": "openmodellab",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "content:registry": "node scripts/generate-content-registry.mjs",
    "content:doctor": "node scripts/content-doctor.mjs",
    "content:variants:status": "node scripts/content-variant-status.mjs",
    "content:variants:validate": "node scripts/content-variant-status.mjs --validate",
    "i18n:translate": "python tools/i18n/translate_content.py",
    "i18n:validate": "python tools/i18n/validate_overlays.py",
    "i18n:worklist": "node scripts/generate-i18n-worklist.mjs",
    "i18n:ping": "python tools/i18n/translate_content.py --ping",
    "i18n:check:zh-HK": "node scripts/check-zhhk-locale-quality.mjs",
    "i18n:sweep:zh-HK": "node scripts/browser-zhhk-site-sweep.mjs",
    "launch:doctor": "node scripts/launch-doctor.mjs",
    "public-release:hygiene": "node scripts/public-release-hygiene-check.mjs",
    "public-release:final-check": "node scripts/public-release-final-check.mjs",
    "public-release:history-audit": "node scripts/public-release-history-audit.mjs",
    "github:labels:plan": "node scripts/github-labels-plan.mjs",
    "wrangler:write": "node scripts/write-wrangler-config.mjs",
    "wrangler:check": "node scripts/write-wrangler-config.mjs --check",
    "ads:write": "node scripts/write-ads-txt.mjs",
    "ads:check": "node scripts/write-ads-txt.mjs --check",
    "deploy:prepare": "node scripts/write-wrangler-config.mjs && node scripts/write-ads-txt.mjs --allow-missing",
    "build": "next build --webpack",
    "prebuild": "node scripts/generate-content-registry.mjs",
    "dev": "next dev",
    "predev": "node scripts/generate-content-registry.mjs",
    "start": "next start",
    "prestart": "node scripts/generate-content-registry.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "pretypecheck": "node scripts/generate-content-registry.mjs",
    "lint": "eslint",
    "prelint": "node scripts/generate-content-registry.mjs",
    "scaffold:concept": "node scripts/scaffold-concept.mjs",
    "validate:content": "node scripts/run-vitest.mjs run tests/content/authoring-tooling.test.ts",
    "prevalidate:content": "node scripts/generate-content-registry.mjs",
    "test": "node scripts/run-vitest.mjs run",
    "pretest": "node scripts/generate-content-registry.mjs",
    "test:watch": "node scripts/run-vitest.mjs watch",
    "test:e2e": "playwright test",
    "test:e2e:concept-v2": "playwright test -c playwright.concept-v2.config.ts",
    "test:e2e:assessment": "playwright test tests/e2e/concept-test-entry-contract.spec.ts tests/e2e/concept-test-standalone.spec.ts tests/e2e/assessment-journeys.spec.ts tests/e2e/assessment-resume.spec.ts tests/e2e/assessment-resume-hydration.spec.ts tests/e2e/assessment-synced-progress.spec.ts tests/e2e/test-hub-recommendations.spec.ts tests/e2e/concept-quiz-retry-flow.spec.ts tests/e2e/learning-surface-concept-tests.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "prepreview": "node scripts/generate-content-registry.mjs && node scripts/write-wrangler-config.mjs",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "predeploy": "node scripts/generate-content-registry.mjs && pnpm deploy:prepare",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preupload": "node scripts/generate-content-registry.mjs && pnpm deploy:prepare",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "katex": "^0.16.25",
    "next": "16.2.1",
    "next-intl": "4.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "intl-messageformat": "^11.2.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.1",
    "wrangler": "^4.79.0"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
