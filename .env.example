# Open Model Lab local environment example.
# Copy to .env.local for local Next.js development. Keep real secrets out of git.
# This is not official production config. Independent deployments need their own
# brand, domains, vendor accounts, keys, legal policies, and private config.

# Site URL
NEXT_PUBLIC_OPEN_MODEL_LAB_SITE_URL=http://localhost:3000
OPEN_MODEL_LAB_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# Supabase auth and account storage
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Stripe Supporter billing
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_PREMIUM_PRICE_ID=your_supporter_price_id_here
STRIPE_PREMIUM_ACHIEVEMENT_COUPON_ID=your_reward_coupon_id_here
STRIPE_API_BASE_URL=

# Feedback delivery
NEXT_PUBLIC_FEEDBACK_EMAIL=feedback@example.com
RESEND_API_KEY=your_resend_api_key_here
FEEDBACK_FROM_EMAIL=Open Model Lab <feedback@example.com>
FEEDBACK_TO_EMAIL=feedback@example.com
FEEDBACK_RESEND_API_BASE_URL=

# Optional analytics relay
NEXT_PUBLIC_ANALYTICS_ENABLED=false
ANALYTICS_WEBHOOK_URL=
ANALYTICS_WEBHOOK_TOKEN=

# Optional support link
NEXT_PUBLIC_OPEN_MODEL_LAB_BUY_ME_A_COFFEE_URL=https://buymeacoffee.com/your-handle
OPEN_MODEL_LAB_BUY_ME_A_COFFEE_URL=https://buymeacoffee.com/your-handle

# AdSense is off by default. Use placeholder IDs only in this file.
OPEN_MODEL_LAB_ADS_TXT_CONTENT=google.com, pub-your-publisher-id, DIRECT, your-certification-authority-id
OPEN_MODEL_LAB_ADS_TXT_SOURCE=path/to/private/ads.txt
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_ENABLED=false
OPEN_MODEL_LAB_ADSENSE_ENABLED=false
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_CLIENT_ID=your_adsense_client_id_here
OPEN_MODEL_LAB_ADSENSE_CLIENT_ID=your_adsense_client_id_here
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_HOME_HERO_BELOW=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_HOME_DISCOVERY=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_HOME_FOOTER_MULTIPLEX=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_CONCEPT_LIBRARY_DISCOVERY=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_CONCEPT_LIBRARY_FOOTER_MULTIPLEX=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_TOPIC_DIRECTORY_DISCOVERY=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_TOPIC_DIRECTORY_FOOTER_MULTIPLEX=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_SUBJECT_DIRECTORY_HEADER_DISPLAY=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_TOPIC_HEADER_DISPLAY=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_TOPIC_FOOTER_MULTIPLEX=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_SUBJECT_HEADER_DISPLAY=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_SUBJECT_FOOTER_MULTIPLEX=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_GUIDED_DIRECTORY_DISCOVERY=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_GUIDED_DIRECTORY_FOOTER_MULTIPLEX=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_SEARCH_RESULTS_DISPLAY=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_CONCEPT_BODY_IN_ARTICLE=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_CONCEPT_POST_LAB_DISPLAY=0000000000
NEXT_PUBLIC_OPEN_MODEL_LAB_ADSENSE_SLOT_CONCEPT_FOOTER_MULTIPLEX=0000000000

# Dev harness and local file stores
ENABLE_DEV_ACCOUNT_HARNESS=false
OPEN_MODEL_LAB_DEV_ACCOUNT_HARNESS_STORE_PATH=output/dev-account-harness.json
OPEN_MODEL_LAB_ACCOUNT_STORE_PATH=output/account-store.json

# Optional zh-HK browser sweep helpers
OPEN_MODEL_LAB_SWEEP_AUTOSTART=false
OPEN_MODEL_LAB_BASE_URL=http://127.0.0.1:3000
OPEN_MODEL_LAB_DEV_BASE_URL=http://127.0.0.1:3100

# Cloudflare/OpenNext local preview
NEXTJS_ENV=development

# Cloudflare/OpenNext private deploy config materialization.
# Set only one of these in a private deploy/build environment.
OPEN_MODEL_LAB_WRANGLER_JSONC_CONTENT=
OPEN_MODEL_LAB_WRANGLER_JSONC_SOURCE=
